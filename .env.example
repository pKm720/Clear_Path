PORT=8080
MONGO_URI=mongodb://localhost:27017/aqi_clearpath
REDIS_URL=redis://localhost:6379

# The endpoint used by the Backend to call your Python AI Inference Pipeline
# For local dev: http://127.0.0.1:8000
# For prod: Replace with where AQI_ML is deployed
ML_API_URL=http://127.0.0.1:8000

# The URL of your web frontend. Restricts API access (CORS).
# For local dev: http://localhost:5173
# For prod: Replace with where AQI_FRONTEND is deployed (e.g., https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173

# External Tokens needed for ingestion
WAQI_TOKEN=your_waqi_api_token
OPENAQ_API_KEY=your_openaq_api_token
